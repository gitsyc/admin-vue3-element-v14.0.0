@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor 用户
participant "业务功能页面"
participant "权限控制服务"
database "权限与组织数据"
participant "审计留痕服务"

== 进入页面并校验可见性 ==
用户 -> "业务功能页面": 进入业务功能页面
activate "业务功能页面"
"业务功能页面" -> "权限控制服务": 获取当前用户可访问菜单与可操作项
activate "权限控制服务"
"权限控制服务" -> "权限与组织数据": 读取用户角色与权限集
activate "权限与组织数据"
"权限与组织数据" --> "权限控制服务": 返回角色、菜单权限、操作权限、关键业务权限
deactivate "权限与组织数据"
"权限控制服务" --> "业务功能页面": 返回可见菜单与可操作项清单
deactivate "权限控制服务"
"业务功能页面" --> 用户: 展示可访问功能与可操作项
deactivate "业务功能页面"

== 查询业务数据并应用数据权限 ==
用户 -> "业务功能页面": 点击查询
activate "业务功能页面"
"业务功能页面" -> "权限控制服务": 获取数据权限范围
activate "权限控制服务"
"权限控制服务" -> "权限与组织数据": 读取数据权限策略与组织归属
activate "权限与组织数据"
"权限与组织数据" --> "权限控制服务": 返回数据范围（区域/门店/个人）与范围明细
deactivate "权限与组织数据"
"权限控制服务" --> "业务功能页面": 返回可查询的数据范围
deactivate "权限控制服务"
"业务功能页面" --> 用户: 展示授权范围内的数据结果
deactivate "业务功能页面"

== 关键业务操作并记录留痕 ==
用户 -> "业务功能页面": 发起关键业务操作\n（如订单作废、退款、调拨）
activate "业务功能页面"
"业务功能页面" -> "权限控制服务": 校验关键业务权限
activate "权限控制服务"
"权限控制服务" -> "权限与组织数据": 校验是否具备该关键权限
activate "权限与组织数据"
"权限与组织数据" --> "权限控制服务": 校验结果（通过/拒绝）
deactivate "权限与组织数据"
alt 通过
  "权限控制服务" --> "业务功能页面": 允许提交
  "业务功能页面" -> "审计留痕服务": 记录操作日志\n（操作人、时间、对象、字段变更）
  activate "审计留痕服务"
  "审计留痕服务" -> "权限与组织数据": 保存审计记录
  activate "权限与组织数据"
  "权限与组织数据" --> "审计留痕服务": 保存成功
  deactivate "权限与组织数据"
  "审计留痕服务" --> "业务功能页面": 记录成功
  deactivate "审计留痕服务"
  "业务功能页面" --> 用户: 显示操作成功
else 拒绝
  "权限控制服务" --> "业务功能页面": 拒绝提交\n返回无权限提示
  "业务功能页面" --> 用户: 显示"无权限执行该操作，请联系管理员开通权限"
end
deactivate "权限控制服务"
deactivate "业务功能页面"

@enduml
